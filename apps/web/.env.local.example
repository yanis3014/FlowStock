# URL de l'API Express (backend). Requis pour tous les appels API (auth, dashboard, etc.)
# En dev : Next tourne sur le port 3001, l'API sur 3000 — utiliser l'URL de l'API ici.
# Voir apps/web/README.md pour les ports et la doc.
NEXT_PUBLIC_API_URL=http://localhost:3000

# URL du service ML (Chat IA). Optionnel ; défaut en code : http://localhost:8000
NEXT_PUBLIC_ML_SERVICE_URL=http://localhost:8000

# Clé API OpenAI pour l'import CSV intelligent (analyse sémantique des colonnes). Optionnel.
# Sans cette clé, le bouton "Analyser avec l'IA" sur /import-stocks affichera une erreur.
OPENAI_API_KEY=
