# Optional: use for integration tests when your main .env has different DB credentials.
# Copy to .env.test and set the password that matches your local PostgreSQL role.
# Jest loads .env first, then .env.test (override), so these values take precedence in tests.
#
# If your .env sets DATABASE_URL, set it here too with the correct password so tests use it.
# DATABASE_URL=postgresql://bmad:bmad@127.0.0.1:5432/bmad_stock_agent
#
# Or override only the password (getDatabaseUrl() uses POSTGRES_* when DATABASE_URL is unset):
POSTGRES_PASSWORD=bmad
